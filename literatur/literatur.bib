@article{unrau_enhancing_2020,
	title = {Enhancing {Usability} {Evaluation} of {Web}-{Based} {Geographic} {Information} {Systems} ({WebGIS}) with {Visual} {Analytics}},
	volume = {177},
	copyright = {Creative Commons Attribution 3.0 Unported license, info:eu-repo/semantics/openAccess},
